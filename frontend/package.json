{
  "name": "cyo_adventure-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"e2e-real/**/*.ts\" \"e2e-staging/**/*.ts\" \"e2e-prod/**/*.ts\" \"playwright.config.ts\" \"playwright.e2e-staging.config.ts\" \"playwright.e2e-prod.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"e2e-real/**/*.ts\" \"e2e-staging/**/*.ts\" \"e2e-prod/**/*.ts\" \"playwright.config.ts\" \"playwright.e2e-staging.config.ts\" \"playwright.e2e-prod.config.ts\" --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc -b",
    "generate-client": "openapi-ts",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:real": "playwright test --project=real-backend --workers=1",
    "test:e2e:staging": "playwright test --config=playwright.e2e-staging.config.ts",
    "test:e2e:prod": "playwright test --config=playwright.e2e-prod.config.ts"
  },
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "@supabase/supabase-js": "^2.110.0",
    "@xstate/react": "^6.1.0",
    "axios": "^1.18.0",
    "idb": "^8.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "xstate": "^5.32.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@hey-api/client-axios": "0.9.1",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "17.4.2",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "fast-check": "4.9.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "^0.25.10",
    "tar": "^7.5.16",
    "handlebars": "^4.7.9",
    "js-yaml": "^5.0.0"
  }
}
