# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/

# Vitest JUnit report (CI-only artifact, uploaded to Codecov Test Analytics)
junit.xml

# Playwright E2E artifacts
playwright-report/
test-results/
blob-report/
/playwright/.cache/

# Environment files (use .env.example as template)
.env
.env.local
.env.*.local

# Generated API client: TRACKED, not ignored. It is committed build output
# (regenerate with `npm run generate-client`) so a CI drift check has a
# baseline to diff against; see docs/template_feedback.md "Generated API
# client is gitignored but CI never regenerates it" for the prior gap.

# TypeScript build info
*.tsbuildinfo

# Vite cache
.vite/
