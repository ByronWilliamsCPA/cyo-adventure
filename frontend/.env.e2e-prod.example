# Credentials for the e2e-prod tier (npm run test:e2e:prod), which signs in
# against LIVE production. Preferred: never populate this file at all, run
# via `infisical run --env=prod -- npm run test:e2e:prod` instead so nothing
# touches disk. Only copy this to .env.e2e-prod (gitignored) as a fallback if
# Infisical isn't available.

E2E_PROD_TEST_EMAIL=
E2E_PROD_TEST_PASSWORD=

# Optional: override the target if it ever moves off the default host.
# E2E_PROD_BASE_URL=https://cyo.williamshome.family
