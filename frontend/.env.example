# Frontend Environment Configuration
# Copy this file to .env.local for local development

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (used during development via Vite proxy)
# In production, this is typically set at build time
VITE_API_URL=http://localhost:8000

# =============================================================================
# Authentication - Supabase Auth (ADR-009; Phase 6 P6-06)
# =============================================================================

# Supabase project URL and anon (public) key. Both required: the guardian
# surface (src/auth/supabaseClient.ts) reads these at module load via
# import.meta.env and throws if either is missing. The anon key is safe to
# ship to the browser; it only grants what Supabase Row Level Security
# policies allow.
# Find both in the Supabase dashboard: Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# =============================================================================
# Feature Flags (optional)
# =============================================================================

# Enable debug mode (shows additional logging)
# VITE_DEBUG=false

# =============================================================================
# Third-Party Services (optional)
# =============================================================================

# Analytics tracking ID
# VITE_ANALYTICS_ID=

# Sentry DSN for frontend error tracking
# VITE_SENTRY_DSN=
