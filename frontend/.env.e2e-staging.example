# Credentials for the e2e-staging tier (npm run test:e2e:staging), which
# signs in against the already-deployed STAGING frontend/Supabase project.
# Only copy this to .env.e2e-staging (gitignored) for a local manual run; CI
# supplies the same variables from the `staging` GitHub Environment's
# secrets (see .github/workflows/e2e-staging.yml).

# Required: no default, this repo has no frontend deploy workflow of its own
# (homelab-infra ships the frontend image separately), so there is no single
# known staging URL to fall back to.
E2E_STAGING_BASE_URL=

# Passwords scripts/seed_staging.py used when creating the test accounts.
# That script never persists these anywhere retrievable, so whoever seeds
# staging must record them here (or in the GitHub Environment secret)
# separately.
E2E_STAGING_GUARDIAN_PASSWORD=
E2E_STAGING_ADMIN_PASSWORD=

# Optional: override if a project's seed ever uses different addresses than
# scripts/seed_staging.py's SEED_GUARDIAN_EMAIL / SEED_ADMIN_EMAIL defaults.
# E2E_STAGING_GUARDIAN_EMAIL=cyo-test-guardian@example.com
# E2E_STAGING_ADMIN_EMAIL=cyo-test-admin@example.com
