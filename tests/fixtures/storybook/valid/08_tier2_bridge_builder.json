{
  "schema_version": "1.0",
  "id": "s_bridge_builder",
  "version": 1,
  "title": "The Bridge Builder",
  "metadata": {
    "age_band": "10-13",
    "reading_level": {
      "scheme": "flesch_kincaid",
      "target": 5.5,
      "tolerance": 1.5
    },
    "tier": 2,
    "themes": [
      "ingenuity",
      "teamwork"
    ],
    "estimated_minutes": 18,
    "ending_count": 3,
    "content_flags": {
      "violence": "none",
      "scariness": "none",
      "peril": "mild"
    },
    "topology": "time_cave"
  },
  "variables": [
    {
      "name": "planks",
      "type": "int",
      "initial": 0,
      "min": 0,
      "max": 5,
      "description": "Number of planks collected for the bridge"
    },
    {
      "name": "has_rope",
      "type": "bool",
      "initial": false,
      "description": "Whether the player carries the rope"
    }
  ],
  "start_node": "n_riverbank",
  "nodes": [
    {
      "id": "n_riverbank",
      "body": "A rushing river blocks your path. Logs and rope scraps lie nearby.",
      "is_ending": false,
      "choices": [
        {
          "id": "c_gather_planks",
          "label": "Drag the logs to the riverbank.",
          "target": "n_workshop",
          "effects": [
            {
              "op": "inc",
              "var": "planks",
              "value": 3
            }
          ]
        },
        {
          "id": "c_find_rope",
          "label": "Search the scraps for usable rope.",
          "target": "n_workshop",
          "effects": [
            {
              "op": "set",
              "var": "has_rope",
              "value": true
            }
          ]
        }
      ]
    },
    {
      "id": "n_workshop",
      "body": "A flat clearing becomes your workshop. What do you have to work with?",
      "is_ending": false,
      "choices": [
        {
          "id": "c_build_plank_bridge",
          "label": "Lash the planks together into a footbridge.",
          "target": "n_crossing",
          "condition": {
            ">=": [
              {
                "var": "planks"
              },
              3
            ]
          }
        },
        {
          "id": "c_build_rope_bridge",
          "label": "String the rope between the banks.",
          "target": "n_crossing",
          "condition": {
            "==": [
              {
                "var": "has_rope"
              },
              true
            ]
          }
        },
        {
          "id": "c_wait_for_help",
          "label": "Wait on the bank and hope someone passes.",
          "target": "n_rescue_end"
        }
      ]
    },
    {
      "id": "n_crossing",
      "body": "Your bridge sways but holds. Step by careful step, you reach the far bank.",
      "is_ending": false,
      "choices": [
        {
          "id": "c_reach_village",
          "label": "Follow the track to the village.",
          "target": "n_village_end"
        },
        {
          "id": "c_explore_ruins",
          "label": "Investigate the old stone ruins.",
          "target": "n_ruins_end"
        }
      ]
    },
    {
      "id": "n_village_end",
      "body": "The village cheers as you arrive. Your bridge stands, and a new path is open.",
      "is_ending": true,
      "ending": {
        "id": "e_hero_builder",
        "valence": "positive",
        "kind": "success",
        "title": "Hero of the River"
      },
      "choices": []
    },
    {
      "id": "n_ruins_end",
      "body": "The ruins conceal a hidden spring that fills the river downstream. Your discovery changes everything.",
      "is_ending": true,
      "ending": {
        "id": "e_discovery",
        "valence": "positive",
        "kind": "success",
        "title": "The Hidden Spring"
      },
      "choices": []
    },
    {
      "id": "n_rescue_end",
      "body": "A traveller with a boat finds you at dusk and ferries you across. Not every problem needs a bridge.",
      "is_ending": true,
      "ending": {
        "id": "e_rescued",
        "valence": "positive",
        "kind": "completion",
        "title": "Unexpected Help"
      },
      "choices": []
    }
  ]
}
