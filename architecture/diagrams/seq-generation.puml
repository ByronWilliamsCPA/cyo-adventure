@startuml seq-generation
' ============================================================
' Sequence Diagram: Staged Generation Pipeline
' Structure -> Prose -> Repair with provider fallback cascade
' and validation gate outcomes
'
' Source files:
'   src/cyo_adventure/generation/orchestrator.py  (module docstring +
'     generate_story(); this diagram covers the fresh_generation method.
'     The skeleton_fill method (fill_skeleton(), worker.py::_run_skeleton_fill)
'     is a separate, not-yet-diagrammed path used for skeleton-matched jobs
'     -- see component-generation.puml for both methods at component level.)
'   src/cyo_adventure/generation/provider.py      (build_provider(): resolves
'     mock|ollama|anthropic|openrouter[+3-leg cascade]|modal, with optional
'     per-job provider_override/model_override, WS-C PR1)
'   src/cyo_adventure/generation/providers/fallback.py  (FallbackProvider cascade)
'   src/cyo_adventure/core/config.py  (openrouter_model, openrouter_fallback_model)
'   src/cyo_adventure/generation/pii.py           (assert_prompt_pii_safe)
'   src/cyo_adventure/generation/guarded.py       (PiiGuardedProvider: wraps
'     the resolved provider so pii.assert_prompt_pii_safe runs on every
'     complete() call, rather than as separate orchestrator-level steps)
'   src/cyo_adventure/generation/prompts.py
'   src/cyo_adventure/validator/gate.py
'   src/cyo_adventure/generation/worker.py
'   docs/planning/adr/adr-003-frontier-llm-generation.md
' ============================================================

skinparam defaultFontName "Roboto"
skinparam backgroundColor #FAFAFA
skinparam roundCorner 8
skinparam sequenceMessageAlign center

actor "Guardian" as guardian
participant "API\ngeneration.py" as api
participant "RQ Worker\nworker.py" as worker
participant "Orchestrator\norchestrator.py" as orch
participant "Prompt Builder\nprompts.py" as prompts
participant "PiiGuardedProvider\nguarded.py + pii.py" as pii
participant "FallbackProvider\nfallback.py" as fallback
participant "OpenRouter\n[leg 1: primary,\nclaude-haiku-4.5]" as or_provider
participant "OpenRouter\n[leg 2: fallback,\nclaude-sonnet-4.6]" as or_provider_fb
participant "Ollama\n[leg 3: local fallback]" as ol_provider
participant "Validator Gate\ngate.py" as gate
database "PostgreSQL\nGenerationJob" as pg

guardian -> api : "POST /concepts/{id}/generate\n(bearer token)"
api -> pg : "INSERT GenerationJob\nstatus='queued'"
api -> api : "BackgroundTask:\n_enqueue_safely(job_id)"
api --> guardian : "202 Accepted\n{job_id, status:'queued'}"
api -> worker : "[RQ] enqueue job_id"

worker -> pg : "UPDATE status='running'"
worker -> orch : "generate_story(brief,\nprovider=PiiGuardedProvider(fallback),\npii)"

' --- Stage A ---
orch -> prompts : "build_structure_prompt(brief)"
prompts --> orch : "StagePrompt (system + user)"
orch -> pii : "provider.complete(system, user, max_tokens=16384)"
pii -> pii : "assert_prompt_pii_safe(system)\nassert_prompt_pii_safe(user)\n(raises ValidationError -> abort\nbefore any provider call)"
pii -> fallback : "complete(system, user, max_tokens=16384)\n[forwarded, PII-safe]"
fallback -> or_provider : "attempt leg 1 (OpenRouter primary)"

alt transient failure (429/5xx)
  or_provider --> fallback : "httpx error / HTTP 429"
  fallback -> fallback : "retry same leg\n(exp. backoff)"
  or_provider --> fallback : "success after retry"
else leg-fatal failure (401/400)
  or_provider --> fallback : "HTTP 401/400"
  fallback -> fallback : "mark leg 1 dead\nfail over to leg 2"
  fallback -> or_provider_fb : "attempt leg 2\n(OpenRouter fallback model)"
  alt leg 2 also leg-fatal
    or_provider_fb --> fallback : "HTTP 401/400"
    fallback -> fallback : "mark leg 2 dead\nfail over to leg 3"
    fallback -> ol_provider : "attempt leg 3 (Ollama)"
    ol_provider --> fallback : "raw text"
  else leg 2 succeeds
    or_provider_fb --> fallback : "raw text"
  end
end

fallback --> pii : "raw text"
pii --> orch : "raw text"
orch -> orch : "json.loads(raw)\n[parse error -> synthetic blocked gate]"
orch -> gate : "run_gate(parsed_doc)"
gate --> orch : "GateResult(blocked, safety_flagged)"

alt Stage A blocked
  orch -> orch : "stage_log: 'stage_a:blocked'\nskip Stage B, go to repair"
else Stage A clean
  orch -> orch : "stage_log: 'stage_a:gate_ok'"

  ' --- Stage B ---
  orch -> prompts : "build_prose_prompt(skeleton_json, brief)"
  prompts --> orch : "StagePrompt"
  orch -> pii : "provider.complete(max_tokens=32000)"
  pii -> pii : "assert_prompt_pii_safe(both blocks)"
  pii -> fallback : "complete()\n[forwarded, PII-safe]"
  fallback -> or_provider : "attempt (or next live leg)"
  or_provider --> fallback : "raw text"
  fallback --> pii : "raw text"
  pii --> orch : "raw text"
  orch -> gate : "run_gate(parsed_doc)"
  gate --> orch : "GateResult"
  orch -> orch : "stage_log: 'stage_b:gate_ok|blocked'"
end

' --- Stage C (Repair loop, runs when blocked) ---
group "Stage C: Repair Loop [while blocked AND attempts < max_repairs=3]"
  orch -> prompts : "build_repair_prompt(current_json, failing_findings)"
  prompts --> orch : "StagePrompt"
  orch -> pii : "provider.complete(max_tokens=32000)"
  pii -> pii : "assert_prompt_pii_safe()"
  pii -> fallback : "complete()\n[forwarded, PII-safe]"
  fallback --> pii : "raw text"
  pii --> orch : "raw text"
  orch -> gate : "run_gate(new_doc)"
  gate --> orch : "GateResult"
  orch -> orch : "check no-progress signature\n(same findings + same doc hash -> abort)"
  orch -> orch : "stage_log: 'repair:N' or 'repair:no_progress_abort'"
end

' --- Outcome mapping ---
orch -> orch : "_build_outcome(gate_result, doc, attempts)"

alt passed: gate clean, not safety_flagged
  orch --> worker : "GenerationOutcome(status='passed', storybook=doc)"
  worker -> pg : "UPDATE status='passed'\nstorybook_id, version, report"
else needs_review: gate clean but safety_flagged
  orch --> worker : "GenerationOutcome(status='needs_review')"
  worker -> pg : "UPDATE status='needs_review'"
else needs_review: blocked after exhausting repairs (doc present)
  orch --> worker : "GenerationOutcome(status='needs_review')"
  worker -> pg : "UPDATE status='needs_review'"
else failed: blocked, no parseable doc produced
  orch --> worker : "GenerationOutcome(status='failed')"
  worker -> pg : "UPDATE status='failed', error=..."
end

guardian -> api : "GET /generation-jobs/{job_id}"
api -> pg : "SELECT GenerationJob"
api --> guardian : "{status, report, storybook_id}"

@enduml
