{
  "description": "Cross-implementation conformance fixtures for the condition DSL (ADR-006). The Python and TypeScript evaluators must return identical results for every case.",
  "schema_version": "2.0",
  "cases": [
    {
      "name": "bare_var_true",
      "condition": { "var": "has_lantern" },
      "var_state": { "has_lantern": true },
      "expected": true
    },
    {
      "name": "bare_var_false",
      "condition": { "var": "has_lantern" },
      "var_state": { "has_lantern": false },
      "expected": false
    },
    {
      "name": "eq_bool_true",
      "condition": { "==": [{ "var": "has_lantern" }, true] },
      "var_state": { "has_lantern": true },
      "expected": true
    },
    {
      "name": "eq_bool_false",
      "condition": { "==": [{ "var": "has_lantern" }, true] },
      "var_state": { "has_lantern": false },
      "expected": false
    },
    {
      "name": "neq_int",
      "condition": { "!=": [{ "var": "courage" }, 0] },
      "var_state": { "courage": 3 },
      "expected": true
    },
    {
      "name": "ge_int_true",
      "condition": { ">=": [{ "var": "courage" }, 3] },
      "var_state": { "courage": 3 },
      "expected": true
    },
    {
      "name": "ge_int_false",
      "condition": { ">=": [{ "var": "courage" }, 3] },
      "var_state": { "courage": 2 },
      "expected": false
    },
    {
      "name": "lt_int_true",
      "condition": { "<": [{ "var": "courage" }, 5] },
      "var_state": { "courage": 4 },
      "expected": true
    },
    {
      "name": "le_int_true",
      "condition": { "<=": [{ "var": "courage" }, 5] },
      "var_state": { "courage": 5 },
      "expected": true
    },
    {
      "name": "gt_int_true",
      "condition": { ">": [{ "var": "courage" }, 3] },
      "var_state": { "courage": 4 },
      "expected": true
    },
    {
      "name": "and_both_true",
      "condition": {
        "and": [
          { "==": [{ "var": "has_key" }, true] },
          { ">=": [{ "var": "trust" }, 2] }
        ]
      },
      "var_state": { "has_key": true, "trust": 2 },
      "expected": true
    },
    {
      "name": "and_one_false",
      "condition": {
        "and": [
          { "==": [{ "var": "has_key" }, true] },
          { ">=": [{ "var": "trust" }, 2] }
        ]
      },
      "var_state": { "has_key": true, "trust": 1 },
      "expected": false
    },
    {
      "name": "or_one_true",
      "condition": { "or": [{ "var": "a" }, { "var": "b" }] },
      "var_state": { "a": false, "b": true },
      "expected": true
    },
    {
      "name": "not_false_is_true",
      "condition": { "!": { "var": "has_curse" } },
      "var_state": { "has_curse": false },
      "expected": true
    },
    {
      "name": "nested_not_and",
      "condition": { "!": { "and": [{ "var": "a" }, { "var": "b" }] } },
      "var_state": { "a": true, "b": false },
      "expected": true
    },
    {
      "name": "ordering_on_string_is_false",
      "condition": { "<": [{ "var": "name" }, 5] },
      "var_state": { "name": "bob" },
      "expected": false
    },
    {
      "name": "eq_across_types_is_false",
      "condition": { "==": [{ "var": "x" }, 5] },
      "var_state": { "x": "5" },
      "expected": false
    },
    {
      "name": "var_literal_comparison_both_sides",
      "condition": { "==": [{ "var": "score" }, { "var": "target" }] },
      "var_state": { "score": 7, "target": 7 },
      "expected": true
    },
    {
      "name": "eq_bool_int_is_false",
      "condition": { "==": [{ "var": "flag" }, 1] },
      "var_state": { "flag": true },
      "expected": false
    },
    {
      "name": "eq_int_int_is_true",
      "condition": { "==": [{ "var": "n" }, 1] },
      "var_state": { "n": 1 },
      "expected": true
    },
    {
      "name": "neq_bool_int_is_true",
      "condition": { "!=": [{ "var": "flag" }, 1] },
      "var_state": { "flag": true },
      "expected": true
    },
    {
      "name": "ge_at_min_boundary",
      "condition": { ">=": [{ "var": "courage" }, 0] },
      "var_state": { "courage": 0 },
      "expected": true
    },
    {
      "name": "le_at_max_boundary",
      "condition": { "<=": [{ "var": "courage" }, 5] },
      "var_state": { "courage": 5 },
      "expected": true
    },
    {
      "name": "lt_below_min_boundary_false",
      "condition": { "<": [{ "var": "courage" }, 0] },
      "var_state": { "courage": 0 },
      "expected": false
    },
    {
      "name": "gt_above_max_boundary_false",
      "condition": { ">": [{ "var": "courage" }, 5] },
      "var_state": { "courage": 5 },
      "expected": false
    },
    {
      "name": "compound_and_with_negation_false",
      "condition": {
        "and": [
          { ">=": [{ "var": "courage" }, 3] },
          { "!": { "var": "has_curse" } }
        ]
      },
      "var_state": { "courage": 2, "has_curse": false },
      "expected": false
    },
    {
      "name": "compound_or_both_false",
      "condition": {
        "or": [
          { "==": [{ "var": "has_lantern" }, true] },
          { ">": [{ "var": "courage" }, 4] }
        ]
      },
      "var_state": { "has_lantern": false, "courage": 2 },
      "expected": false
    },
    {
      "name": "lt_bool_var_left_is_false",
      "condition": { "<": [{ "var": "flag" }, 1] },
      "var_state": { "flag": false },
      "expected": false
    },
    {
      "name": "gt_bool_var_left_is_false",
      "condition": { ">": [{ "var": "flag" }, 0] },
      "var_state": { "flag": true },
      "expected": false
    },
    {
      "name": "ge_bool_vars_both_sides_is_false",
      "condition": { ">=": [{ "var": "a" }, { "var": "b" }] },
      "var_state": { "a": true, "b": false },
      "expected": false
    },
    {
      "name": "le_bool_var_right_is_false",
      "condition": { "<=": [{ "var": "n" }, { "var": "flag" }] },
      "var_state": { "n": 0, "flag": true },
      "expected": false
    },
    {
      "name": "lt_missing_var_is_false",
      "condition": { "<": [{ "var": "ghost" }, 5] },
      "var_state": {},
      "expected": false
    },
    {
      "name": "defensive_lt_false_literal_is_false",
      "condition": { "<": [false, 1] },
      "var_state": {},
      "expected": false
    },
    {
      "name": "defensive_gt_true_literal_is_false",
      "condition": { ">": [true, 0] },
      "var_state": {},
      "expected": false
    },
    {
      "name": "eq_missing_var_defaults_false",
      "condition": { "==": [{ "var": "ghost" }, false] },
      "var_state": {},
      "expected": true
    },
    {
      "name": "bare_missing_var_is_false",
      "condition": { "var": "ghost" },
      "var_state": {},
      "expected": false
    },
    {
      "name": "truthy_int_zero_is_false",
      "condition": { "var": "count" },
      "var_state": { "count": 0 },
      "expected": false
    },
    {
      "name": "truthy_nonzero_int_is_true",
      "condition": { "var": "count" },
      "var_state": { "count": 3 },
      "expected": true
    },
    {
      "name": "literal_only_eq_is_true",
      "condition": { "==": [2, 2] },
      "var_state": {},
      "expected": true
    },
    {
      "name": "literal_only_ordering_is_true",
      "condition": { "<": [2, 3] },
      "var_state": {},
      "expected": true
    },
    {
      "name": "eq_int_at_literal_bound_is_true",
      "condition": { "==": [{ "var": "gold" }, 1000000000] },
      "var_state": { "gold": 1000000000 },
      "expected": true
    },
    {
      "name": "defensive_nested_condition_operand_is_literal_false_not_evaluated",
      "condition": { "==": [{ "var": "a" }, { "!": { "var": "a" } }] },
      "var_state": { "a": false },
      "expected": true
    }
  ]
}
