@startuml er-diagram
' ============================================================
' Entity-Relationship Diagram: all 22 ORM Tables
' CYO Adventure
'
' Source file:
'   src/cyo_adventure/db/models.py  (SQLAlchemy ORM, all tables, columns, FKs)
'
' Note: all timestamps are TIMESTAMP WITH TIME ZONE (timezone-aware).
' Enum columns (role, status, age_band, ...) are stored as strings, each
' backed by a CHECK constraint (plain Supabase CLI SQL migrations; the closed
' vocabulary is enforced at rest as well as at the application boundary).
'
' This diagram draws every table in models.py (22 total). See
' docs/architecture/data-model.md for the full, authoritative column
' dictionary.
' ============================================================

skinparam defaultFontName "Roboto"
skinparam backgroundColor #FAFAFA
skinparam roundCorner 8

entity "family" as family #E8F5E9 {
  * id : UUID <<PK>>
  --
  name : VARCHAR(200)
  monthly_story_quota : INT NULL [ADR-015 cost gate; NULL = platform default]
  created_at : TIMESTAMPTZ
  deactivated_at : TIMESTAMPTZ NULL [soft-deactivate; cascades to members]
}

entity "series" as series #C8E6C9 {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  title : VARCHAR(120)
  age_band : VARCHAR(16) [3-5 | 5-8 | 8-11 | 10-13 | 13-16 | 16+]
  carries_state : BOOLEAN [episodic vs stateful, ADR-011]
  created_by : UUID <<FK user.id, NULL>>
  created_at : TIMESTAMPTZ
}

entity "user" as user_t #E3F2FD {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  role : VARCHAR(16) [guardian | child | admin]
  is_admin : BOOLEAN [default false; capability orthogonal to role]
  authn_subject : VARCHAR(255) <<UNIQUE>>
  email : VARCHAR(320) NULL [contact only, never an identity key]
  child_profile_id : UUID <<FK child_profile.id, NULL>>
  created_at : TIMESTAMPTZ
  status : VARCHAR(16) [pending|active|deactivated, default active]
  --
  CHECK (role<>'child' OR is_admin=false)
  CHECK (role<>'admin' OR is_admin=true)
}

entity "child_profile" as child_profile #FFF3E0 {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  display_name : VARCHAR(120)
  age_band : VARCHAR(16) [3-5 | 5-8 | 8-11 | 10-13 | 13-16 | 16+]
  reading_level_cap : FLOAT [default 99.0]
  allowed_content_flags : JSONB
  banned_themes : JSONB NULL [G2 guardian theme exclusions]
  tts_enabled : BOOLEAN
  avatar : VARCHAR(255) NULL
  pin_hash : TEXT NULL [write-only PIN; never serialized]
  request_auto_approve : BOOLEAN [ADR-015 G3; default false]
  monthly_request_envelope : INT NULL [ADR-015 G3 auto-approve cap]
  created_at : TIMESTAMPTZ
  deactivated_at : TIMESTAMPTZ NULL [soft-remove; history preserved]
}

entity "family_connection" as family_connection #E8F5E9 {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>> [viewer / opted-in]
  * connected_family_id : UUID <<FK family.id>> [recommendation source]
  created_by : UUID <<FK user.id, NULL>>
  created_at : TIMESTAMPTZ
  consented_by_viewer_user_id : UUID <<FK user.id, NULL>> [ADR-016 G17]
  consented_by_viewer_at : TIMESTAMPTZ NULL
  consented_by_sharer_user_id : UUID <<FK user.id, NULL>>
  consented_by_sharer_at : TIMESTAMPTZ NULL
  --
  UNIQUE (family_id, connected_family_id)
  CHECK (family_id <> connected_family_id)
  CHECK (viewer consent id/at both NULL or both set)
  CHECK (sharer consent id/at both NULL or both set)
}

entity "storybook" as storybook #F3E5F5 {
  * id : VARCHAR(120) <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  current_published_version : INT NULL
  status : VARCHAR(20) [draft|in_review|needs_revision|published|archived]
  visibility : VARCHAR(16) [family|catalog, default family, WS-E]
  created_by : UUID <<FK user.id, NULL>>
  series_id : UUID <<FK series.id, NULL>>
  book_index : INT NULL [UNIQUE with series_id]
  created_at : TIMESTAMPTZ
}

entity "storybook_version" as storybook_version #F3E5F5 {
  * storybook_id : VARCHAR(120) <<PK, FK storybook.id>>
  * version : INT <<PK>>
  --
  blob : JSONB [Storybook JSON content]
  blob_ref : VARCHAR(512) NULL [MinIO key, Phase 5]
  validation_report : JSONB NULL
  moderation_report : JSONB NULL
  approved_by : UUID <<FK user.id, NULL>>
  published_at : TIMESTAMPTZ NULL
  model : VARCHAR(120) NULL [LLM model id]
  prompt_version : VARCHAR(120) NULL
  provider : VARCHAR(120) NULL [mock|anthropic|openrouter|modal|ollama|import]
  skeleton_slug : VARCHAR(120) NULL [WS-C PR2 provenance]
  created_at : TIMESTAMPTZ
  cover_image_url : VARCHAR(512) NULL
  cover_status : VARCHAR(20) [none|generating|ready|failed]
}

entity "reading_state" as reading_state #E0F7FA {
  * child_profile_id : UUID <<PK, FK child_profile.id>>
  * storybook_id : VARCHAR(120) <<PK, FK storybook.id>>
  --
  version : INT [pinned to storybook_version via composite FK]
  current_node : VARCHAR(120)
  var_state : JSONB
  path : JSONB
  visit_set : JSONB [drives once:true effects]
  save_slots : JSONB
  state_revision : INT [server-owned OCC counter]
  last_event_id : VARCHAR(64) NULL [idempotency key]
  updated_by_device_id : VARCHAR(64) NULL
  last_synced_at : TIMESTAMPTZ NULL
  created_at : TIMESTAMPTZ
  updated_at : TIMESTAMPTZ
}

entity "completion" as completion #DCEDC8 {
  * child_profile_id : UUID <<PK, FK child_profile.id>>
  * storybook_id : VARCHAR(120) <<PK>>
  * version : INT <<PK>>
  * ending_id : VARCHAR(120) <<PK>>
  --
  found_at : TIMESTAMPTZ
}

entity "rating" as rating #FFF9C4 {
  * child_profile_id : UUID <<PK, FK child_profile.id>>
  * storybook_id : VARCHAR(120) <<PK, FK storybook.id>>
  --
  value : INT [1-5]
  rated_at : TIMESTAMPTZ
  updated_at : TIMESTAMPTZ [mutable: re-rate overwrites]
}

entity "storybook_assignment" as storybook_assignment #CFD8DC {
  * child_profile_id : UUID <<PK, FK child_profile.id>>
  * storybook_id : VARCHAR(120) <<PK, FK storybook.id>>
  --
  assigned_by : UUID <<FK user.id, NULL>> [NULL = system backfill]
  created_at : TIMESTAMPTZ
}

entity "concept" as concept #FFF8E1 {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  brief : JSONB [ConceptBrief payload]
  created_by : UUID <<FK user.id, NULL>>
  created_at : TIMESTAMPTZ
}

entity "story_request" as story_request #FFE0B2 {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  profile_id : UUID <<FK child_profile.id, NULL>>
  request_text : VARCHAR(500)
  status : VARCHAR(16) [pending|approved|declined|blocked]
  initiator_role : VARCHAR(16) [child|guardian|admin, default child]
  age_band : VARCHAR(16)
  length : VARCHAR(16) NULL [short|medium|long]
  narrative_style : VARCHAR(16) [prose|gamebook, default prose]
  moderation_flags : JSONB NULL [redacted screening findings]
  reviewed_by : UUID <<FK user.id, NULL>>
  reviewed_at : TIMESTAMPTZ NULL
  approved_at : TIMESTAMPTZ NULL [ADR-015; set once on approve]
  concept_id : UUID <<FK concept.id, NULL>> [set on approval]
  series_id : UUID <<FK series.id, NULL>>
  anchor_storybook_id : VARCHAR(120) <<FK storybook.id, NULL>>
  proposed_series_title : VARCHAR(120) NULL
  created_at : TIMESTAMPTZ
}

entity "moderation_threshold" as moderation_threshold #FFCDD2 {
  * id : UUID <<PK>>
  --
  age_band : VARCHAR(16)
  category : VARCHAR(64)
  min_verdict : VARCHAR(16) [advisory|flag|block]
  min_score : FLOAT NULL [0.0-1.0]
  updated_by : UUID <<FK user.id, NULL>>
  updated_at : TIMESTAMPTZ
  --
  UNIQUE (age_band, category)
}

entity "moderation_threshold_audit" as moderation_threshold_audit #FFCDD2 {
  * id : UUID <<PK>>
  --
  age_band : VARCHAR(16)
  category : VARCHAR(64)
  action : VARCHAR(16) [upsert|delete]
  old_min_verdict : VARCHAR(16) NULL
  new_min_verdict : VARCHAR(16) NULL
  old_min_score : FLOAT NULL
  new_min_score : FLOAT NULL
  changed_by : UUID <<FK user.id>> [NOT NULL]
  changed_at : TIMESTAMPTZ
  --
  append-only (no update/delete path)
}

entity "moderation_setting" as moderation_setting #FFCDD2 {
  * key : VARCHAR(64) <<PK>> [e.g. "admin_noise_floor"]
  --
  value : FLOAT [0.0-1.0]
  updated_by : UUID <<FK user.id, NULL>>
  updated_at : TIMESTAMPTZ
}

entity "pipeline_event" as pipeline_event #ECEFF1 {
  * id : UUID <<PK>>
  --
  occurred_at : TIMESTAMPTZ
  actor_id : UUID <<FK user.id, NULL>> [NULL iff actor_role='system']
  actor_role : VARCHAR(16) [system|guardian|child|admin|device]
  entity_type : VARCHAR(32) [story_request|generation_job|storybook|...]
  entity_id : VARCHAR(255)
  event_type : VARCHAR(48) [20 values, see EventType]
  from_state : VARCHAR(32) NULL
  to_state : VARCHAR(32) NULL
  payload : JSONB [PII-free, allowlisted fields only]
  --
  append-only (DB trigger enforced)
}

entity "provider_model_allowlist" as provider_model_allowlist #D1C4E9 {
  * id : UUID <<PK>>
  --
  provider : VARCHAR(32) [anthropic|openrouter|modal|ollama]
  model_id : VARCHAR(120)
  enabled : BOOLEAN [default true]
  display_name : VARCHAR(120) NULL
  created_by : UUID <<FK user.id, NULL>>
  updated_by : UUID <<FK user.id, NULL>>
  created_at : TIMESTAMPTZ
  updated_at : TIMESTAMPTZ
  --
  UNIQUE (provider, model_id)
}

entity "provider_model_allowlist_audit" as provider_model_allowlist_audit #D1C4E9 {
  * id : UUID <<PK>>
  --
  provider : VARCHAR(32)
  model_id : VARCHAR(120)
  action : VARCHAR(16) [create|update|delete]
  old_enabled : BOOLEAN NULL
  new_enabled : BOOLEAN NULL
  changed_by : UUID <<FK user.id>> [NOT NULL]
  changed_at : TIMESTAMPTZ
  --
  append-only (no update/delete path)
}

entity "device_grant" as device_grant #B3E5FC {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>>
  * authorized_by : UUID <<FK user.id>>
  label : VARCHAR(120) NULL [guardian-facing device name]
  jti : UUID <<UNIQUE>> [revocation lookup key]
  created_at : TIMESTAMPTZ
  revoked_at : TIMESTAMPTZ NULL [set, not deleted, on revoke]
}

entity "generation_job" as generation_job #FFEBEE {
  * id : UUID <<PK>>
  --
  * concept_id : UUID <<FK concept.id>>
  status : VARCHAR(20) [queued|running|passed|needs_review|failed|\nawaiting_manual_fill]
  model : VARCHAR(120) NULL
  provider : VARCHAR(120) NULL
  prompt_version : VARCHAR(120) NULL
  report : JSONB NULL [GenerationOutcome JSON]
  authoring_metadata : JSONB NULL [skeleton_slug, theme_brief, ...]
  storybook_id : VARCHAR(120) NULL [NOT FK, see note]
  version : INT NULL
  error : VARCHAR(512) NULL
  created_at : TIMESTAMPTZ
  updated_at : TIMESTAMPTZ
}

entity "kid_flag" as kid_flag #FCE4EC {
  * id : UUID <<PK>>
  --
  * family_id : UUID <<FK family.id>> [denormalized from profile]
  * profile_id : UUID <<FK child_profile.id>>
  * storybook_id : VARCHAR(120) <<FK storybook.id>>
  version : INT [composite FK (storybook_id, version) -> storybook_version]
  reason : VARCHAR(16) [did_not_like|scared_me|confusing]
  node_id : VARCHAR(120) NULL [story-graph node id, never prose (ADR-016)]
  created_at : TIMESTAMPTZ
  resolved_by : UUID <<FK user.id, NULL>>
  resolved_at : TIMESTAMPTZ NULL
  resolution : VARCHAR(16) NULL [dismissed|archived_book|noted]
  --
  CHECK (reason in did_not_like|scared_me|confusing)
  CHECK (resolution NULL or in dismissed|archived_book|noted)
  CHECK (resolved_by/resolved_at both NULL or both set)
}

