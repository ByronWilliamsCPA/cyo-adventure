@startuml c4-context
' ============================================================
' C4 Level 1 - System Context Diagram
' CYO Adventure: Choose-Your-Own-Adventure reading app for kids
'
' Source files:
'   src/cyo_adventure/api/deps.py      (Principal/role model)
'   src/cyo_adventure/api/generation.py (guardian-only authoring)
'   src/cyo_adventure/api/reading.py   (child reading endpoints)
'   docs/planning/adr/adr-005-mandatory-human-approval.md
'   docs/planning/adr/adr-003-frontier-llm-generation.md
'   docs/planning/tech-spec.md
' ============================================================

!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v2.4.0
skinparam defaultFontName "Roboto"
skinparam backgroundColor #FAFAFA
skinparam roundCorner 8

skinparam rectangle {
  BorderColor #555555
  FontColor #222222
}

skinparam actor {
  BorderColor #555555
  FontColor #222222
  BackgroundColor #FFFFFF
}

' --- Actors ---
actor "Child Reader\n(age 8-16)" as child #E3F2FD
actor "Guardian / Author\n(parent or carer)" as guardian #E8F5E9

' --- System boundary ---
rectangle "CYO Adventure System\n[Homelab, Docker, Pangolin zero-trust]" as system #FFF3E0 {
  rectangle "PWA Reader\n[React 19, TypeScript]\nPlay stories, offline support" as pwa #E3F2FD
  rectangle "FastAPI Backend\n[Python 3.12]\nLibrary, generation, reading state,\nguardian review" as backend #E8F5E9
}

' --- External systems ---
rectangle "OpenRouter\n[Primary LLM provider]\nMulti-model API gateway" as openrouter #F3E5F5
rectangle "Ollama\n[Local fallback LLM]\nSelf-hosted, homelab" as ollama #FFEBEE
rectangle "Authentik\n[OIDC identity provider]\nGuardian and child roles" as authentik #E0F7FA
rectangle "PostgreSQL\n[Operational database]\nMetadata and reading state" as postgres #FFF8E1
rectangle "Redis + RQ\n[Job queue]\nAsync generation jobs" as redis #E0E0E0

' --- Relationships ---
child --> pwa : "Reads stories,\nchooses paths"
guardian --> pwa : "Authors concepts,\napproves stories (ADR-005)"
pwa --> backend : "REST /api/v1\n(OIDC bearer token)"
backend --> openrouter : "LLM completions\n(primary, ADR-003)"
backend ..> ollama : "LLM completions\n(local fallback)"
backend --> authentik : "OIDC token validation"
backend --> postgres : "Async SQLAlchemy 2"
backend --> redis : "Enqueue generation jobs"

note bottom of pwa
  Generated API client in
  frontend/src/client/ (build output,
  not hand-written) from OpenAPI schema.
  Service worker + IndexedDB for offline play.
end note

note right of openrouter
  Provider fallback cascade:
  OpenRouter (primary) ->
  Ollama (local fallback)
  Layer 1: per-adapter retry
  Layer 2: FallbackProvider cascade
  Layer 3: orchestrator repair loop
end note

note bottom of backend
  Mandatory human approval (ADR-005):
  no story reaches a child profile without
  a recorded guardian approval.
  State machine: draft -> generating ->
  auto_check -> in_review -> approved ->
  published -> archived
end note

@enduml
