@startuml deployment
' ============================================================
' Deployment View: Homelab-first Docker deployment
' CYO Adventure
'
' Source files:
'   docs/planning/adr/adr-004-homelab-first-deployment.md
'   docs/planning/adr/adr-009-supabase-platform.md (Supabase OIDC replaces Authentik as
'     app IdP; decision 2 = Supabase Postgres as the operational database)
'   docs/planning/r1-gap-closure-plan.md (Task 1.7: cut over the operational database
'     to Supabase Postgres, session pooler, homelab-infra #576/#577)
'   docs/planning/tech-spec.md  (Infrastructure section)
'   CLAUDE.md (Docker, Pangolin zero-trust, Dockge)
'
' Note: MinIO shown as planned (deferred Phase 5).
' Note: homelab Authentik keeps its existing internal homelab-service roles
' (ADR-009) but is no longer the app's OIDC identity provider. All app
' principals, guardians and the global admin approver alike, authenticate
' via Supabase OIDC (the admin is a Supabase identity with is_admin), shown below.
' Note: the operational database moved from the local cyo-postgres container to
' Supabase Postgres (ADR-009 decision 2; R1 Task 1.7, deployed 2026-07-05 via
' homelab-infra #576), reached through the session pooler (session mode: each
' connection gets a dedicated backend; no transaction-mode/PgBouncer
' prepared-statement workaround). cyo-postgres is retained for one redeploy
' only as a rollback fallback, is off the data path, and is tracked for
' removal in homelab-infra #577.
' ============================================================

skinparam defaultFontName "Roboto"
skinparam backgroundColor #FAFAFA
skinparam roundCorner 8

node "Family Devices\n[browsers, tablets]" as devices #E3F2FD {
  component "PWA\n(React 19 SPA)\nService Worker\n+ IndexedDB" as pwa_client #DDEEFF
}

cloud "OpenRouter API\nhttps://openrouter.ai\n[default cascade legs 1-2]" as openrouter_cloud #F3E5F5
cloud "Anthropic / Modal APIs\n[admin-selectable per-job\nprovider legs, WS-C PR1]" as extra_provider_cloud #F3E5F5
cloud "Supabase Auth\n[OIDC provider, ADR-009]\nGuardian + admin sign-in (Apple/Google)" as supabase_cloud #E0F7FA
cloud "Supabase Postgres\n[Managed DB, ADR-009 decision 2]\nSession pooler:\naws-0-us-east-1.pooler.supabase.com:5432\n(session mode; dedicated backend\nper connection, R1 Task 1.7)" as supabase_pg_cloud #E0F7FA

node "Homelab Server\n[Docker + Dockge]\n(ADR-004)" as homelab #E8F5E9 {

  node "Pangolin\n[Zero-trust reverse proxy\nTailscale / Cloudflare Tunnel]" as pangolin #CCEECC {
    component "TLS termination\nHTTPS -> internal HTTP" as tls #CCEECC
  }

  node "cyo-backend\n[Docker container\ncyo-backend:latest]" as backend_container #B2DFDB {
    component "FastAPI app\n(uvicorn, port 8000)\nsrc/cyo_adventure/\ncorrelation + security MW" as fastapi_app #B2DFDB
    component "Static PWA assets\n(served by FastAPI\nor separate nginx)" as static_assets #B2DFDB
  }

  node "cyo-worker\n[Docker container\ncyo-worker:latest]" as worker_container #FFF3E0 {
    component "RQ Worker\ngeneration/worker.py\nasync, long-running\nno inbound HTTP" as rq_worker #FFF3E0
  }

  node "cyo-postgres [retained for rollback]\n[Docker container\npostgres:16-alpine]\nOff the data path; being retired\n(homelab-infra #577)" as postgres_container #ECEFF1 {
    database "PostgreSQL 16 (idle)\nport 5432\nRetained one redeploy only\nas a rollback fallback" as pg_db #ECEFF1
  }

  node "cyo-redis\n[Docker container\nredis:7-alpine]" as redis_container #E0E0E0 {
    database "Redis 7\nport 6379\nRQ job queue\n(no persistence required)" as redis_db #E0E0E0
  }

  node "cyo-ollama\n[Docker container\nollama/ollama:latest]" as ollama_container #FFEBEE {
    component "Ollama\nport 11434\nlocal LLM fallback\n(GPU if available)" as ollama_svc #FFEBEE
  }

  node "cyo-minio [planned Phase 5]\n[Docker container\nminio/minio]" as minio_container #E0E0E0 {
    database "MinIO\nS3-compatible\nStorybook blob storage\nblog_ref column" as minio_db #E0E0E0
  }

}

' --- Network flows ---
pwa_client --> tls : "HTTPS (443)"
tls --> fastapi_app : "HTTP (8000)"
fastapi_app --> supabase_pg_cloud : "async SQLAlchemy 2\nsession pooler :5432"
fastapi_app --> redis_db : "rq.Queue\n6379"
fastapi_app --> ollama_svc : "HTTP\n11434"
rq_worker --> redis_db : "dequeue\n6379"
rq_worker --> supabase_pg_cloud : "update job\nsession pooler :5432"
rq_worker --> openrouter_cloud : "HTTPS\nLLM completions\n(primary)"
rq_worker ..> extra_provider_cloud : "HTTPS\nadmin-selected job override\n(anthropic/modal)"
rq_worker ..> ollama_svc : "HTTP\nLLM fallback"
rq_worker ..> minio_db : "[Phase 5]\nS3 API"
pwa_client --> supabase_cloud : "OIDC auth flow\n(Apple/Google via Supabase)"
fastapi_app --> supabase_cloud : "OIDC token validation\n[non-local; local uses token-as-subject]"

note right of postgres_container
  Retained for one redeploy only as a
  rollback fallback (R1 Task 1.7); carries
  no live traffic since 2026-07-05. Tracked
  for removal in homelab-infra #577.
end note

note right of worker_container
  The worker runs in a separate container
  so long-running generation (30-120s) does
  not block the API event loop.
  Worker and API share the same image
  or a shared base; Dockge manages the
  compose stack.
end note

note right of minio_container
  Phase 1: blob stored inline as JSONB
  on storybook_version.blob.
  Phase 5: MinIO container added;
  blob_ref column set to S3 object key.
end note

note bottom of pwa_client
  PWA assets cached by service worker
  (Workbox via vite-plugin-pwa).
  IndexedDB stores reading state for
  offline play. Offline write queue
  replays on reconnect with event_id
  idempotency.
end note

@enduml
