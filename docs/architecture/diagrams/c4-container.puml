@startuml c4-container
' ============================================================
' C4 Level 2 - Container Diagram
' CYO Adventure: containers and their interactions
'
' Source files:
'   src/cyo_adventure/app.py           (FastAPI app wiring)
'   src/cyo_adventure/api/             (routers)
'   src/cyo_adventure/generation/worker.py  (RQ worker)
'   src/cyo_adventure/core/database.py (async SQLAlchemy)
'   frontend/src/client/               (generated OpenAPI client)
'   frontend/src/offline/sync.ts       (offline queue)
'   docs/planning/tech-spec.md
'   docs/planning/adr/adr-002-client-pwa.md
'   docs/planning/adr/adr-004-homelab-first-deployment.md
'   docs/planning/adr/adr-009-supabase-platform.md (Supabase OIDC replaces Authentik;
'     decision 2 = Supabase Postgres as the operational database)
'   docs/planning/r1-deferred-debt-register.md (Task 1.7: Supabase Postgres cutover;
'     r1-gap-closure-plan.md is archived, consolidated here)
' ============================================================

skinparam defaultFontName "Roboto"
skinparam backgroundColor #FAFAFA
skinparam roundCorner 8

skinparam rectangle {
  BorderColor #555555
  FontColor #222222
}

actor "Child Reader" as child #E3F2FD
actor "Guardian" as guardian #E8F5E9
actor "Admin\n(global safety operator,\ncross-family, ADR-005)" as admin #EDE7F6

' --- PWA ---
rectangle "PWA Container\n[React 19, TypeScript, Vite]\nServed as static assets" as pwa #E3F2FD {
  rectangle "Reader UI\nfrontend/src/reader/" as reader #DDEEFF
  rectangle "Library UI\nfrontend/src/api/" as library_ui #DDEEFF
  rectangle "Player\nfrontend/src/player/\nTS evaluator + XState machine" as player_ui #DDEEFF
  rectangle "Offline Layer\nfrontend/src/offline/\nIndexedDB + write queue" as offline #DDEEFF
  rectangle "Generated API Client\nfrontend/src/client/ [BUILD OUTPUT]\nfrom OpenAPI schema via hey-api" as gen_client #E0E0E0
}

' --- Backend ---
rectangle "FastAPI Backend\n[Python 3.12, FastAPI, Pydantic v2]\nsrc/cyo_adventure/" as backend #E8F5E9 {
  rectangle "API Routers (21)\nhealth, library, reading, generation,\nprofiles, families, ratings, assignments,\napproval [global admin], covers,\nmoderation_thresholds [admin],\nmoderation_dashboard [admin],\nprovider_allowlist [admin], me,\nstory_requests, child_sessions,\ndevice_grants, onboarding,\nadmin_users [admin], admin_profiles [admin],\nfamily_connections [admin]" as routers #CCEECC
  rectangle "Auth Seam\napi/deps.py\nPrincipal / family / role + is_admin\n(guardian, child, admin, device)" as auth #CCEECC
  rectangle "Storybook Domain\nstorybook/models.py\nstorybook/evaluator.py\nstorybook/condition.py" as storybook_dom #CCEECC
  rectangle "Player Engine\nplayer/engine.py\nRuntime Semantics v1 (pure)" as player_eng #CCEECC
  rectangle "Validator Gate\nvalidator/gate.py\nL1+Policy+L2+RL+SAFE layers" as validator #CCEECC
  rectangle "Generation Orchestrator\ngeneration/orchestrator.py\nfresh_generation (Stage A->B->C)\nor skeleton_fill (fill_skeleton)" as orchestrator #CCEECC
  rectangle "Moderation\nmoderation/pipeline.py, thresholds.py\nfidelity_review.py, repair.py" as moderation_comp #CCEECC
  rectangle "Publishing\npublishing/state_machine.py\napprove -> publish gate (ADR-005)" as publishing_comp #CCEECC
  rectangle "Pipeline Event Log\nevents/writer.py [WS-D]\nappend-only lifecycle audit" as events_comp #CCEECC
  rectangle "Middleware\nmiddleware/correlation.py\nmiddleware/security.py" as middleware #CCEECC
}

' --- Generation Worker ---
rectangle "Generation Worker\n[RQ worker process]\ngeneration/worker.py" as worker #FFF3E0

' --- Data stores ---
database "Supabase Postgres\n[Managed DB, ADR-009 decision 2]\nSession pooler :5432 (session mode)\n21 ORM tables:\nFamily, FamilyConnection, Series, User,\nChildProfile, Storybook, StorybookVersion,\nReadingState, Completion, Rating,\nStorybookAssignment, Concept,\nStoryRequest, ModerationThreshold(+Audit),\nModerationSetting, PipelineEvent,\nProviderModelAllowlist(+Audit),\nGenerationJob, DeviceGrant" as postgres #E0F7FA

database "Redis\n[Job broker]\nRQ queue for generation jobs" as redis #E0E0E0

rectangle "MinIO\n[Object storage, deferred Phase 5]\nStorybook blobs via S3 API" as minio #E0E0E0

' --- External LLMs ---
rectangle "OpenRouter\n[Primary LLM, default cascade]" as openrouter #F3E5F5
rectangle "Anthropic / Modal\n[Admin-selectable per-job\nprovider legs, WS-C PR1]" as extra_providers #F3E5F5
rectangle "Ollama\n[Local fallback]" as ollama #FFEBEE
rectangle "Supabase Auth\n[OIDC, ADR-009]" as supabase_auth #E0F7FA

' --- Relationships ---
child --> reader
guardian --> library_ui
admin --> library_ui : "review + approve\nstorybooks (cross-family)"
reader --> player_ui
player_ui --> offline : "local state\ncache"
gen_client --> routers : "REST /api/v1\n(Bearer token)"
offline ..> gen_client : "queue replay\n(event_id idempotency)"
routers --> auth : "Depends()"
routers --> orchestrator
routers --> validator
routers --> storybook_dom
routers --> player_eng
routers --> moderation_comp
routers --> publishing_comp
routers --> events_comp : "write PipelineEvent\n(same transaction)"
backend --> postgres : "async SQLAlchemy 2\nsession pooler :5432"
backend --> redis : "enqueue job\n(BackgroundTask)"
worker --> redis : "dequeue job"
worker --> orchestrator : "generate_story()\nor fill_skeleton()"
worker --> moderation_comp : "post-gate review"
worker --> openrouter : "provider.complete()\n(default provider)"
worker ..> extra_providers : "provider.complete()\n(admin-selected job override)"
worker ..> ollama : "fallback"
worker --> postgres : "update GenerationJob\nsession pooler :5432"
worker ..> minio : "[planned Phase 5]\nblob_ref store"
backend --> supabase_auth : "OIDC validation\n[local: token-as-subject seam;\nnon-local: verified Supabase JWT]"

note bottom of gen_client
  Regenerated from http://localhost:8000/openapi.json
  via: npm run generate-client
  Never hand-edit files in frontend/src/client/
end note

note right of minio
  Phase 1: blob stored inline
  on storybook_version.blob (JSONB).
  blob_ref column reserved for
  MinIO object key (Phase 5).
end note

@enduml
