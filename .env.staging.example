# =============================================================================
# CYO Adventure - STAGING environment (Supabase staging project)
# =============================================================================
# Copy to `.env.staging` and fill from the Supabase dashboard (staging
# project): Settings > Database (connection string, session mode) and
# Settings > API (Project URL, publishable key, secret key). Supabase's
# current dashboard issues the new `sb_publishable_...` / `sb_secret_...` key
# formats shown below (legacy `anon` / `service_role` JWTs still work if your
# project predates the rotation, but prefer the new keys for new projects).
# Usage: uv run --env-file .env.staging <command>
# NEVER commit .env.staging (already git-ignored). No real secrets in this
# template; every value below is a placeholder.

ENVIRONMENT=staging

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Supabase Supavisor pooler)
# -----------------------------------------------------------------------------
# Session-mode pooler (port 5432), the default below, works with asyncpg's
# prepared-statement cache as-is. The transaction-mode pooler (port 6543) is
# faster under load but reassigns backend connections mid-session, so it
# requires CYO_ADVENTURE_DATABASE_DISABLE_PREPARED_CACHE=true or the app
# refuses to start (see core/config.py's pooler-port validator).
CYO_ADVENTURE_DATABASE_URL=postgresql+asyncpg://postgres.<staging-ref>:<db-password>@<pooler-host>:5432/postgres
# CYO_ADVENTURE_DATABASE_DISABLE_PREPARED_CACHE=true

# -----------------------------------------------------------------------------
# Authentication - OIDC / Supabase Auth (ADR-009)
# -----------------------------------------------------------------------------
# Backend JWT verification against the staging project's GoTrue issuer. Both
# REQUIRED outside "local" (see core/config.py's OIDC validator).
OIDC_ISSUER=https://<staging-ref>.supabase.co/auth/v1
OIDC_JWKS_URL=https://<staging-ref>.supabase.co/auth/v1/.well-known/jwks.json
OIDC_AUDIENCE=authenticated

# -----------------------------------------------------------------------------
# Child sessions - kid-surface tokens (G1 / P6-04)
# -----------------------------------------------------------------------------
# Signs the guardian-minted, child-scoped HS256 session tokens. REQUIRED outside
# "local" (see core/config.py's child-session validator). Generate a fresh
# high-entropy value (>=32 bytes), distinct from any other environment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
CHILD_SESSION_SECRET=REPLACE_ME
# Optional; defaults to 43200 (12h) if unset.
# CHILD_SESSION_TTL_SECONDS=43200

# -----------------------------------------------------------------------------
# Device grants - durable device authorization (ADR-014 phase 1)
# -----------------------------------------------------------------------------
# Signs the guardian-minted, family-scoped, durable HS256 device grant tokens.
# REQUIRED outside "local" (see core/config.py's device-grant validator).
# MUST be a different value than CHILD_SESSION_SECRET. Generate a fresh
# high-entropy value (>=32 bytes), distinct from any other environment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DEVICE_GRANT_SECRET=REPLACE_ME
# Optional; defaults to 7776000 (90 days) if unset.
# DEVICE_GRANT_TTL_SECONDS=7776000

# -----------------------------------------------------------------------------
# Supabase admin API (staging seed script only; secret key is SECRET)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<staging-ref>.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_REPLACE_ME

# -----------------------------------------------------------------------------
# Frontend (copy into frontend/.env.local when pointing the UI at staging)
# -----------------------------------------------------------------------------
# Deliberate deviation from .env.example's split convention: local dev keeps
# separate backend (.env.example) and frontend (frontend/.env.example)
# templates, but staging is a single combined template covering both, since
# one Supabase project backs both surfaces for this environment.
VITE_SUPABASE_URL=https://<staging-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME

# -----------------------------------------------------------------------------
# Story generation - stays unbilled on staging (local/homelab Ollama, never a
# metered provider), so test runs place no billed LLM calls.
# -----------------------------------------------------------------------------
CYO_ADVENTURE_GENERATION_PROVIDER=ollama
# OLLAMA_BASE_URL=... / OLLAMA_AUTH=... / OLLAMA_CA_BUNDLE=... (see .env.example)

# -----------------------------------------------------------------------------
# Cover generation (nano banana) + Cloudflare R2 storage
# -----------------------------------------------------------------------------
# Same five R2 vars as .env.example; see that file for setup detail. NOTE:
# unlike story generation above, cover generation places billed Gemini image
# calls; leave GEMINI_API_KEY unset to disable covers on staging entirely.
# Staging shares the production bucket ("cyo") and its public custom domain
# by owner decision, so R2_BUCKET below is a real value, not a placeholder.
# The covers WORKER process needs these same vars in its own environment.
# GEMINI_API_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=cyo
# R2_PUBLIC_BASE_URL=https://cyo-bucket.williamshome.family

# -----------------------------------------------------------------------------
# Seed script inputs (scripts/seed_staging.py)
# -----------------------------------------------------------------------------
# Test account identities. Passwords are set at seed time via
# SEED_GUARDIAN_PASSWORD / SEED_ADMIN_PASSWORD (exported in the shell, never
# stored in this file) so a leaked .env.staging cannot grant login access.
SEED_GUARDIAN_EMAIL=cyo-test-guardian@example.com
SEED_ADMIN_EMAIL=cyo-test-admin@example.com
