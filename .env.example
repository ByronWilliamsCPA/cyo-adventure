# =============================================================================
# CYO Adventure - Backend & Docker Compose environment
# =============================================================================
# Copy to `.env` and set only what you need. This file configures the FastAPI
# backend (Pydantic Settings in src/cyo_adventure/core/config.py) and the
# docker-compose stack.
#
# Scope:
#   - The React app has its OWN example at frontend/.env.example
#     (VITE_* and Supabase browser keys). Do not duplicate those here.
#   - CI-only tokens (Codecov, SonarCloud, Infisical machine identity, the
#     Anthropic review-workflow key) live in GitHub Secrets and are documented
#     in README.md, not in this file.
#
# Naming convention: backend settings use the CYO_ADVENTURE_ prefix, EXCEPT the
# handful read from unprefixed names via validation_alias (ENVIRONMENT,
# OPENROUTER_API_KEY, OLLAMA_*, OPENAI_API_KEY, PERSPECTIVE_API_KEY, OIDC_*).
# Never commit real secrets; source them from a secret manager (Infisical).

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------
# Deployment stage: local | dev | staging | production. Any non-local value
# activates the fail-fast startup guards in core/config.py (a real database URL
# and OIDC config both become mandatory).
ENVIRONMENT=local
LOG_LEVEL=INFO
JSON_LOGS=false

# -----------------------------------------------------------------------------
# Database (PostgreSQL, async SQLAlchemy)
# -----------------------------------------------------------------------------
# Local dev defaults to peer/trust auth (no password), so this can stay unset.
# Set it if your local Postgres requires a password. REQUIRED in every non-local
# environment: the app refuses to start with the dev default outside "local".
# CYO_ADVENTURE_DATABASE_URL=postgresql+asyncpg://postgres:<password>@localhost:5432/cyo_adventure
#
# docker-compose Postgres service knobs:
DB_PASSWORD=password
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis (RQ generation queue) - optional
# -----------------------------------------------------------------------------
# Only needed when running the background generation queue. Defaults to local.
# CYO_ADVENTURE_REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Story generation providers
# -----------------------------------------------------------------------------
# Which LLM backend generates stories: mock | claude | ollama | openrouter.
# "mock" (default) makes no live calls, so CI and local runs stay free/offline.
# CYO_ADVENTURE_GENERATION_PROVIDER=mock

# OpenRouter (cloud). Required only when a provider is set to openrouter.
OPENROUTER_API_KEY=
# Optional model override (defaults are pinned in config.py per ADR-003):
# CYO_ADVENTURE_OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Ollama (local or homelab). A plain local instance (http://localhost:11434)
# needs no credentials; leave the three vars below unset for that. The homelab
# host is fronted by Traefik + Authentik and needs all three:
#   OLLAMA_BASE_URL  - HTTPS vhost, NO :11434, and NOT the *.svc wildcard
#                      (the svc-cyo identity is not authorized on the wildcard).
#   OLLAMA_AUTH      - HTTP Basic "user:password"; the user is exactly "svc-cyo"
#                      (no -<device> suffix), the password is the Authentik app
#                      password (mint one per device).
#   OLLAMA_CA_BUNDLE - path to the Homelab CA bundle so TLS verifies against the
#                      privately-signed cert (proper verification, not a bypass);
#                      omit for a plain-HTTP local Ollama.
# OLLAMA_BASE_URL=https://ollama.williamshome.family
# OLLAMA_AUTH=svc-cyo:<app-password>
# OLLAMA_CA_BUNDLE=certs/homelab-ca.pem

# Reserved direct-provider hooks (not read yet; wired in a later slice):
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# PERPLEXITY_API_KEY=

# -----------------------------------------------------------------------------
# Content moderation / safety review (Phase 3)
# -----------------------------------------------------------------------------
# Independent review backend: mock | ollama | openrouter | modal. "mock"
# (default) runs no real review. The reviewing model must come from a different
# provider than the generation model to preserve the independence invariant.
# When set to a live provider, at least one Stage-0 classifier key below MUST be
# set or the app refuses to start.
CYO_ADVENTURE_REVIEW_PROVIDER=mock
# Stage-0 deterministic classifiers (both optional; each unset one is skipped):
# OpenAI Moderation API (omni-moderation-latest; free; sexual/minors category):
OPENAI_API_KEY=
# Google Perspective API (Comment Analyzer; free with quota):
PERSPECTIVE_API_KEY=

# -----------------------------------------------------------------------------
# Authentication - OIDC / Supabase Auth (ADR-009; Phase 6)
# -----------------------------------------------------------------------------
# Guardian bearer tokens are verified as real OIDC JWTs in every environment
# except "local". Outside "local", BOTH vars below are REQUIRED at startup;
# there would otherwise be no way to verify a bearer token. Provider-agnostic by
# design: the values point at Supabase's GoTrue issuer today, but the backend
# verifies signatures via jwt.PyJWKClient and imports no Supabase SDK. Find both
# under Supabase dashboard > Project Settings > API. The browser-side
# VITE_SUPABASE_* keys belong in frontend/.env.example, not here.
# OIDC_ISSUER=https://your-project-ref.supabase.co/auth/v1
# OIDC_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
# Expected `aud` claim. Supabase issues "authenticated" for any signed-in user;
# only change this if the project has a custom audience configured.
OIDC_AUDIENCE=authenticated

# -----------------------------------------------------------------------------
# Docker Compose stack knobs (docker-compose.yml / docker-compose.prod.yml)
# -----------------------------------------------------------------------------
# Image tag. Production REQUIRES an explicit immutable release tag or digest.
VERSION=latest
# Host ports:
APP_PORT=8000
FRONTEND_PORT=3000
# Backend URL baked into the frontend production build:
VITE_API_URL=http://localhost:8000
# Replica counts (production):
REPLICAS=2
FRONTEND_REPLICAS=1

# -----------------------------------------------------------------------------
# Observability - Sentry (optional; not yet wired into the backend)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
